# Canonical public URL (no trailing slash). Used for Open Graph, canonical links,
# JSON-LD, and sitemap generation. On Netlify you can rely on automatic URL instead.
# VITE_SITE_URL=https://your-site.netlify.app

# Optional: website inquiry + Contact page via https://web3forms.com (free tier, no SMTP).
# In Web3Forms, set the form’s notification email to match app/seo/site.ts SITE_INQUIRY_EMAIL.
# Add VITE_WEB3FORMS_ACCESS_KEY wherever the app is **built** (Netlify, Render, GitHub Actions, etc.),
# then redeploy — Vite bakes it into the JS bundle at build time, not at runtime.
# Render: Dashboard → your Web Service → Environment → add for **Build** (same name), redeploy.
# VITE_WEB3FORMS_ACCESS_KEY=your_access_key_here
#
# Optional: force Netlify Forms fallback when building off Netlify but deploying there:
# VITE_NETLIFY_FORMS=true
